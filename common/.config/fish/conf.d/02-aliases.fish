# ==============================================================================
# 🚀 ALIASES — SISTEMA
# ==============================================================================

# Navegação e utilitários
alias c="clear"
alias ..="cd .."
alias ...="cd ../.."

# Ferramentas modernas (substitui defaults)
alias cat="bat" # cat com syntax highlighting
alias ls="eza --icons" # ls com ícones
alias ll="eza -lha --icons --grid --group-directories-first --git"
alias lt="eza --tree --level=2 --icons"

# Processos
alias psc="ps aux | grep" # grep de processos

# Matrix
alias matrix="unimatrix -c green -s 96 -l kns -a"
