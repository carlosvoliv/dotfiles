{
    "layer": "top",
    "position": "top",
    "height": 28,
    "spacing": 0,
    "modules-left": [
        "custom/arch",
        "hyprland/window"
    ],
    "modules-center": [
        "hyprland/workspaces",
        "hyprland/submap"
    ],
    "modules-right": [
        "tray",
        "group/controls",
        "custom/search",
        "custom/clock", // Data e hora corrigidas aqui
        "custom/notification"
    ],

    "custom/arch": {
        "format": " ´îâ ",
        "on-click": "wlogout -b 6 -C /home/kadu/.config/wlogout/style.css -l /home/kadu/.config/wlogout/layout",
        "tooltip": false
    },

    "hyprland/window": {
        "format": " {}",
        "max-length": 50,
        "separate-outputs": true
    },

    "hyprland/workspaces": {
        "format": "{icon}",
        "on-click": "activate",
        "all-outputs": true,
        "sort-by-number": true,
        "format-icons": {
            "urgent": "´ü▒",
            "active": "´åÆ",
            "default": "´äî"
        }
    },

    "group/controls": {
        "orientation": "horizontal",
        "modules": [
            "network",
            "pulseaudio",
            "battery"
        ]
    },

    "network": { 
        "format-wifi": "{icon}", 
        "format-ethernet": "¾░ú║",
        "format-disconnected": "¾░ñ«", 
        "tooltip-format": "{essid} - {signalStrength}%", 
        "format-icons": ["¾░ñ»", "¾░ñƒ", "¾░ñó", "¾░ñÑ", "¾░ñ¿"], 
        "on-click": "~/.config/waybar/scripts/wifi-menu.sh"
    },

    "pulseaudio": {
        "format": "{icon}",
        "format-muted": "¾░Øƒ",
        "tooltip-format": "{volume}%",
        "format-icons": {
            "default": ["´Çª", "´Çº", "´Ç¿"]
        },
        "on-click": "pavucontrol"
    },

    "battery": {
        "states": { "warning": 30, "critical": 15 },
        "format": "{icon}",
        "tooltip-format": "{capacity}% | {timeTo}",
        "format-charging": "´âº",
        "format-icons": ["´ëä", "´ëâ", "´ëé", "´ëü", "´ëÇ"]
    },

    "custom/search": {
        "format": " ´Çé ",
        "on-click": "wofi --show drun",
        "tooltip": false
    },

    "custom/clock": {
    "exec": "~/.config/waybar/scripts/date-pt.sh",
    "interval": 60,
    "format": "{}",  // <-- AQUI est├í o format
    "tooltip": false,
    "on-click": "~/.config/waybar/scripts/smart_calendar.sh"
    },

    "custom/notification": {
        "tooltip": false,
        "format": "{icon}",
        "format-icons": {
            "notification": "´â│ ", // (Opcional) Sino com pontinho vermelho
            "none": "´â│ ", // Sino normal
            "dnd-notification": "´çÂ ", // N├úo perturbe + notif
            "dnd-none": "´çÂ ", // N├úo perturbe vazio
            "inhibited-notification": "´â│ ",
            "inhibited-none": "´â│ ",
            "dnd-inhibited-notification": "´çÂ ",
            "dnd-inhibited-none": "´çÂ "
        },
        "return-type": "json",
        "exec-if": "which swaync-client",
        "exec": "swaync-client -swb",
        "on-click": "swaync-client -t -sw",
        "on-click-right": "swaync-client -d -sw",
        "escape": true
    },
    
    "tray": {
        "icon-size": 16,
        "spacing": 10
    },
    "hyprland/submap": {
        "format": "´åÆ", 
        "max-length": 8,
        "tooltip": false
    },
}
